<mvc:View controllerName="zfioriar.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizfeeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout">
    <App>
        <pages>
            <Page id="page" title="{i18n>title}">
                <content>
                    <VBox class="sapUiSmallMargin">
                        <FlexBox alignItems="Start" justifyContent="Start" wrap="Wrap">
                            <VBox class="sapUiMediumMarginEnd sapUiSmallMarginBottom">
                                <Label text="公司代码" labelFor="companyCodeInput" />
                                <Input id="companyCodeInput" width="200px" />
                            </VBox>
                            <VBox class="sapUiMediumMarginEnd sapUiSmallMarginBottom">
                                <Label text="企业所属集团" labelFor="groupInput" />
                                <Input id="groupInput" width="200px" />
                            </VBox>
                            <VBox class="sapUiMediumMarginEnd sapUiSmallMarginBottom">
                                <Label text="客户编码" required="true" />
                                <Input id="customerInput"
                                    width="200px"
                                    placeholder="输入客户编码或名称..."
                                    showSuggestion="true"
                                    liveChange=".onLiveChange"
                                    suggestionItems="{customerModel>/data}">
                                    <suggestionItems>
                                        <core:ListItem key="{customerModel>customer_id}"
                                            text="{customerModel>customer_id}"
                                            additionalText="{customerModel>customer_name}" />
                                    </suggestionItems>
                                </Input>
                            </VBox>
                        </FlexBox>
                        <HBox class="sapUiSmallMarginTop">
                            <Button text="查询"
                                type="Emphasized"
                                press=".onSearch"
                                width="100px" />
                        </HBox>
                    </VBox>
                    <Table id="customerTable" items="{ar>/data}">
                        <columns>
                            <Column>
                                <Text text="公司代码" />
                            </Column>
                            <Column>
                                <Text text="公司名称" />
                            </Column>
                            <Column>
                                <Text text="企业所属集团" />
                            </Column>
                            <Column
                                minScreenWidth="Small"
                                demandPopin="true">
                                <Text text="客户编码" />
                            </Column>
                            <Column
                                minScreenWidth="Small"
                                demandPopin="true">
                                <Text text="客户名称" />
                            </Column>
                            <Column
                                minScreenWidth="Small"
                                demandPopin="true">
                                <Text text="应收账款" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{ar>bukrs}" />
                                    <Text text="{ar>butxt}" />
                                    <Text text="{ar>group}" />
                                    <Text text="{ar>customer_id}" />
                                    <Text text="{ar>customer_name}" />
                                    <Text text="{ar>receivable_amount}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </content>
            </Page>
        </pages>
    </App>
</mvc:View>